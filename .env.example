# PROVES Library Environment Variables

# Anthropic (Primary LLM - Claude Sonnet 4.5)
ANTHROPIC_API_KEY=sk-ant-api03-your_anthropic_api_key_here

# PostgreSQL Database
# Option A: Neon (cloud, free tier available - https://neon.tech)
NEON_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/proves

# Option B: Local PostgreSQL (requires Docker or local install)
# NEON_DATABASE_URL=postgresql://user:password@localhost:5432/proves

PGVECTOR_ENABLED=true

# LangSmith (Tracing and Observability)
LANGCHAIN_TRACING_V2=true
LANGSMITH_API_KEY=lsv2_sk_your_langsmith_api_key_here
LANGSMITH_PROJECT=PROVES_Library

# Optional: LangSmith Workspace (for enterprise accounts)
# LANGSMITH_WORKSPACE_ID=your_workspace_id

# GitHub (Optional: for documentation fetching)
# GITHUB_TOKEN=ghp_your_github_token_here

# OpenAI (Optional: for comparison/legacy extraction)
# OPENAI_API_KEY=sk-your_openai_api_key_here

# ============================================
# CURATION DASHBOARD PLATFORM
# ============================================

# Supabase (Database + Auth + Real-time)
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_service_role_key_here

# Supabase Database Connection (if using Supabase instead of Neon)
# SUPABASE_DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Resend (Email Notifications)
# Get this from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# Email Configuration
# The "from" address for notification emails (must be verified in Resend)
EMAIL_FROM=noreply@yourdomain.com
# Alternative for testing (use resend.dev domain)
# EMAIL_FROM=onboarding@resend.dev

# Dashboard Configuration
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000
# For production: https://proves-dashboard.vercel.app
