# PROVES Library Environment Variables

# ============================================
# REQUIRED: LLM API KEY
# ============================================

# Anthropic (Primary LLM - Claude Sonnet 4.5)
ANTHROPIC_API_KEY=sk-ant-api03-your_anthropic_api_key_here

# ============================================
# REQUIRED: DATABASE (Supabase)
# ============================================

# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_service_role_key_here

# Database connection URL (from Settings > Database > Connection string > Direct)
# Use port 5432 for direct connection (not 6543 pooler)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Alias for backward compatibility
PROVES_DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

PGVECTOR_ENABLED=true

# ============================================
# OPTIONAL: TRACING & OBSERVABILITY
# ============================================

# LangSmith (Tracing and Observability)
LANGCHAIN_TRACING_V2=true
LANGSMITH_API_KEY=lsv2_sk_your_langsmith_api_key_here
LANGSMITH_PROJECT=PROVES_Library

# Optional: LangSmith Workspace (for enterprise accounts)
# LANGSMITH_WORKSPACE_ID=your_workspace_id

# ============================================
# OPTIONAL: ADDITIONAL SERVICES
# ============================================

# GitHub (Optional: for documentation fetching)
# GITHUB_TOKEN=ghp_your_github_token_here

# OpenAI (Optional: for comparison/legacy extraction)
# OPENAI_API_KEY=sk-your_openai_api_key_here

# ============================================
# OPTIONAL: TEAM COLLABORATION SOURCES
# ============================================

# Notion API (for team wikis, docs, meeting notes)
# Create integration at: https://www.notion.so/my-integrations
# Then share pages/databases with your integration
NOTION_API_KEY=secret_your_notion_integration_token_here

# Google Drive/Docs/Sheets API
# Create service account at: https://console.cloud.google.com/iam-admin/serviceaccounts
# Enable Drive API, Docs API, and Sheets API
# Download JSON credentials file
GOOGLE_SERVICE_ACCOUNT_FILE=path/to/service-account-credentials.json
# OR paste JSON directly (for deployment environments):
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Discord Bot (for team discussions)
# Create bot at: https://discord.com/developers/applications
# Enable MESSAGE_CONTENT intent for reading messages
# Invite bot to your server with Read Message History permission
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Resend (Email Notifications)
# Get this from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# Email Configuration
# The "from" address for notification emails (must be verified in Resend)
EMAIL_FROM=noreply@yourdomain.com
# Alternative for testing (use resend.dev domain)
# EMAIL_FROM=onboarding@resend.dev

# Dashboard Configuration
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000
# For production: https://proves-dashboard.vercel.app
